# Application mode:
# mock - runs fully on demonstrative local fixtures, no API keys required.
# api  - tries adapter calls first and falls back to mocks on errors.
DATA_MODE=mock
REPOSITORY_PROVIDER=mock

# PostgreSQL is required for Prisma persistence and seed workflow.
DATABASE_URL="postgresql://gamevalue:gamevalue@localhost:5432/gamevalue_radar?schema=public"
# Direct non-pooled URL for Prisma migrations. For local Docker this can match DATABASE_URL.
DIRECT_URL="postgresql://gamevalue:gamevalue@localhost:5432/gamevalue_radar?schema=public"

# Optional future integrations. Keep real secrets in .env only, never in git.
STEAM_WEB_API_KEY=""
# Backward-compatible legacy name; prefer STEAM_WEB_API_KEY in new environments.
STEAM_API_KEY=""
PRICE_API_PROVIDER="mock"
PRICE_API_KEY=""
ISTHEREANYDEAL_API_KEY=""
GG_DEALS_API_KEY=""

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Comma-separated list of origins allowed to call /api from mobile clients.
# In development, Capacitor/Vite localhost origins are allowed by default.
MOBILE_ALLOWED_ORIGINS="capacitor://localhost,http://localhost,http://localhost:5173,http://127.0.0.1:5173,http://10.0.2.2:5173"

# Secret for manual/admin POST endpoints. Do not expose it to mobile.
ADMIN_API_SECRET=""

# Optional secret for cron-only refresh endpoints. Do not expose it to mobile.
CRON_SECRET=""
