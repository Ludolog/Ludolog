# Application mode:
# mock - runs fully on demonstrative local fixtures, no API keys required.
# api  - uses backend/API data; mock fallback is disabled unless explicitly enabled for dev.
DATA_MODE=mock
REPOSITORY_PROVIDER=mock
ENABLE_DEV_MOCK_FALLBACK="false"

# PostgreSQL is required for Prisma persistence and seed workflow.
DATABASE_URL="postgresql://gamevalue:gamevalue@localhost:5432/gamevalue_radar?schema=public"
# Direct non-pooled URL for Prisma migrations. For local Docker this can match DATABASE_URL.
DIRECT_URL="postgresql://gamevalue:gamevalue@localhost:5432/gamevalue_radar?schema=public"

# Optional future integrations. Keep real secrets in .env only, never in git.
STEAM_WEB_API_KEY=""
# Backward-compatible legacy name; prefer STEAM_WEB_API_KEY in new environments.
STEAM_API_KEY=""
PRICE_PROVIDER="gamevalue"
PRICE_MODE="internal"

# GOG store connector for internal GameValue Price API. Disabled by default.
GOG_ENABLED="false"
GOG_API_BASE_URL="https://api.gog.com"
GOG_CATALOG_BASE_URL="https://catalog.gog.com"
GOG_COUNTRY_CODE="PL"
GOG_CURRENCY="PLN"
GOG_REQUEST_LIMIT_PER_HOUR="200"
# Public GOG offers stay hidden by default while the connector is admin/experimental.
SHOW_GOG_PUBLIC="false"

# Experimental Steam Store JSON price connector. Disabled by default.
STEAM_STORE_PRICE_ENABLED="false"
STEAM_STORE_API_BASE_URL="https://store.steampowered.com/api"
STEAM_STORE_COUNTRY="PL"
STEAM_STORE_CURRENCY="PLN"
STEAM_STORE_PRICE_CACHE_TTL_MINUTES="360"
STEAM_STORE_PRICE_MAX_PER_RUN="20"

# Capped production refresh automation. Keep catalog backfill disabled until dry runs are verified.
PRICE_REFRESH_ENABLED="true"
PRICE_REFRESH_IMPORTED_LIMIT="20"
PRICE_REFRESH_STEAM_STORE_LIMIT="20"
PRICE_REFRESH_GOG_LIMIT="10"
PRICE_REFRESH_CATALOG_BACKFILL_ENABLED="false"
PRICE_REFRESH_CATALOG_BACKFILL_LIMIT="10"
PRICE_REFRESH_MAX_RUNTIME_MS="25000"
PLAYER_COUNT_REFRESH_LIMIT="25"
PLAYER_COUNT_REFRESH_MAX_RUNTIME_MS="25000"
PLAYER_COUNT_STALE_MINUTES="30"
STEAM_STORE_PRICE_STALE_HOURS="6"
GOG_PRICE_STALE_HOURS="12"
CATALOG_PRICE_STALE_HOURS="168"

# Curated production scope for practical Steam tracking. Keep limits capped at 100.
TOP_GAMES_REFRESH_ENABLED="true"
TOP_GAMES_PLAYER_REFRESH_LIMIT="100"
TOP_GAMES_PRICE_REFRESH_LIMIT="100"
TOP_GAMES_STALE_PLAYER_HOURS="6"
TOP_GAMES_STALE_PRICE_HOURS="12"

# Legacy external price providers are disabled unless this flag is set explicitly.
ENABLE_LEGACY_PRICE_PROVIDERS="false"
GGDEALS_API_KEY=""
# Optional override. Default: https://gg.deals/api/prices/by-steam-app-id/
GGDEALS_API_BASE_URL=""
# Optional GG.deals market preferences. Keep these backend-only.
GGDEALS_REGION="pl"
GGDEALS_CURRENCY="PLN"
# Legacy names kept for backward compatibility. Do not use these for active price flow.
PRICE_API_PROVIDER="gamevalue"
PRICE_API_KEY=""
ISTHEREANYDEAL_API_KEY=""
GG_DEALS_API_KEY=""

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Comma-separated list of origins allowed to call /api from mobile clients.
# In development, Capacitor/Vite localhost origins are allowed by default.
MOBILE_ALLOWED_ORIGINS="capacitor://localhost,http://localhost,http://localhost:5173,http://127.0.0.1:5173,http://10.0.2.2:5173"

# Secret for manual/admin POST endpoints. Do not expose it to mobile.
ADMIN_API_SECRET=""

# Optional secret for cron-only refresh endpoints. Do not expose it to mobile.
CRON_SECRET=""
