generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum DataSource {
  mock
  steam_api
  price_api
  prisma
  ggdeals
  manual
  gog
  steam_store
}

enum Recommendation {
  buy_now
  wait
  weak_deal
}

enum IntegrationLevel {
  info
  warning
  error
}

enum IntegrationService {
  steam
  steam_store
  ggdeals
  gog
  price
  price_cleanup
  search
  snapshot
  alerts
}

model Game {
  id                   String                @id
  steamAppId           Int                   @unique
  title                String
  slug                 String                @unique
  platform             String
  description          String
  coverUrl             String
  genres               String[]
  developer            String
  publisher            String
  releaseDate          DateTime
  reviewScore          Int
  source               DataSource            @default(mock)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  offers               StoreOffer[]
  priceSnapshots       GamePriceSnapshot[]
  playerCountSnapshots PlayerCountSnapshot[]
  externalMappings     GameExternalMapping[]
  watchlistItems       Watchlist[]
  priceAlerts          PriceAlert[]
  scoreSnapshots       DealScoreSnapshot[]
}

model PriceSource {
  id        String              @id
  name      String              @unique
  type      String
  isActive  Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  offers    StoreOffer[]
  snapshots GamePriceSnapshot[]

  @@index([type])
  @@index([isActive])
}

model Store {
  id         String       @id
  name       String
  slug       String       @unique
  storeType  String       @default("unknown")
  websiteUrl String?
  isActive   Boolean      @default(true)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  offers     StoreOffer[]

  @@index([storeType])
  @@index([isActive])
}

model SteamCatalogEntry {
  id                String     @id
  steamAppId        Int        @unique
  title             String
  appType           String
  lastModified      Int?
  priceChangeNumber Int?
  isGame            Boolean    @default(true)
  isActive          Boolean    @default(true)
  source            DataSource @default(steam_api)
  syncedAt          DateTime
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([title])
  @@index([isGame, isActive])
  @@index([syncedAt])
}

model GogCatalogEntry {
  id           String   @id
  gogProductId String   @unique
  title        String
  slug         String
  url          String?
  imageUrl     String?
  isActive     Boolean  @default(true)
  productType  String?
  rawData      Json?
  syncedAt     DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([title])
  @@index([slug])
  @@index([isActive])
  @@index([syncedAt])
}

model GameExternalMapping {
  id           String   @id
  gameId       String
  game         Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  provider     String
  externalId   String
  externalSlug String?
  confidence   String   @default("unknown")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([gameId, provider])
  @@unique([provider, externalId])
  @@index([provider])
  @@index([provider, externalSlug])
}

model StoreOffer {
  id              String      @id
  gameId          String
  game            Game        @relation(fields: [gameId], references: [id], onDelete: Cascade)
  steamAppId      Int?
  storeId         String?
  store           Store?      @relation(fields: [storeId], references: [id], onDelete: SetNull)
  sourceId        String?
  priceSource     PriceSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  provider        String      @default("mock")
  storeName       String
  storeType       String      @default("unknown")
  title           String?
  price           Decimal     @db.Decimal(10, 2)
  regularPrice    Decimal?    @db.Decimal(10, 2)
  historicalLow   Decimal?    @db.Decimal(10, 2)
  currency        String
  discountPercent Int
  url             String
  externalUrl     String?
  region          String      @default("PL")
  isOfficial      Boolean
  isOfficialStore Boolean     @default(false)
  isHistoricalLow Boolean     @default(false)
  available       Boolean     @default(true)
  drm             String
  platform        String      @default("PC")
  sourceRawId     String?
  rawProviderData Json?
  source          DataSource  @default(mock)
  fetchedAt       DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime

  @@index([gameId])
  @@index([steamAppId])
  @@index([storeId])
  @@index([sourceId])
  @@index([provider])
  @@index([source])
}

model GamePriceSnapshot {
  id              String      @id
  gameId          String
  game            Game        @relation(fields: [gameId], references: [id], onDelete: Cascade)
  steamAppId      Int?
  sourceId        String?
  priceSource     PriceSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  provider        String      @default("mock")
  storeType       String      @default("unknown")
  price           Decimal     @db.Decimal(10, 2)
  historicalLow   Decimal     @db.Decimal(10, 2)
  basePrice       Decimal     @db.Decimal(10, 2)
  discountPercent Int
  storeName       String
  currency        String
  externalUrl     String?
  offerCount      Int         @default(1)
  isHistoricalLow Boolean     @default(false)
  sourceRawId     String?
  rawProviderData Json?
  fetchedAt       DateTime?
  capturedAt      DateTime
  createdAt       DateTime    @default(now())
  source          DataSource  @default(mock)

  @@index([gameId, capturedAt])
  @@index([steamAppId])
  @@index([sourceId])
  @@index([provider])
  @@index([source])
}

model PlayerCountSnapshot {
  id            String     @id
  gameId        String
  game          Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)
  steamAppId    Int
  playersOnline Int
  capturedAt    DateTime
  source        DataSource @default(mock)

  @@index([gameId, capturedAt])
  @@index([steamAppId])
}

model DealScoreSnapshot {
  id             String         @id
  gameId         String
  game           Game           @relation(fields: [gameId], references: [id], onDelete: Cascade)
  score          Int
  recommendation Recommendation
  factors        Json
  reason         String
  capturedAt     DateTime

  @@index([gameId, capturedAt])
}

model User {
  id             String       @id
  email          String       @unique
  name           String
  createdAt      DateTime     @default(now())
  watchlistItems Watchlist[]
  priceAlerts    PriceAlert[]
}

model Watchlist {
  id           String   @id
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameId       String
  game         Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  targetPrice  Decimal? @db.Decimal(10, 2)
  alertEnabled Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@unique([userId, gameId])
  @@index([gameId])
}

model PriceAlert {
  id             String    @id
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameId         String
  game           Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)
  thresholdPrice Decimal   @db.Decimal(10, 2)
  isActive       Boolean   @default(true)
  triggeredAt    DateTime?
  createdAt      DateTime  @default(now())

  @@index([userId])
  @@index([gameId])
}

model IntegrationLog {
  id        String             @id
  service   IntegrationService
  level     IntegrationLevel
  message   String
  createdAt DateTime           @default(now())
}
