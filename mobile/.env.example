# Android emulator can reach the host machine through 10.0.2.2.
VITE_API_BASE_URL=http://10.0.2.2:3000

# For browser preview on the same computer, use:
# VITE_API_BASE_URL=http://127.0.0.1:3000

# For a physical Android phone, use your computer LAN address, for example:
# VITE_API_BASE_URL=http://192.168.1.20:3000
