{
  "name": "gamevalue-radar-mobile",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Mobile Android client for GameValue Radar.",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "build:dev": "tsc -p tsconfig.json --noEmit && vite build --mode development",
    "build:prod": "tsc -p tsconfig.json --noEmit && vite build --mode production",
    "preview": "vite preview --host 0.0.0.0",
    "sync": "cap sync android",
    "android:open": "cap open android",
    "android:run": "cap run android",
    "android:build": "cd android && gradlew.bat assembleDebug",
    "android:build:release": "cd android && gradlew.bat assembleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/splash-screen": "^7.0.0",
    "@capacitor/status-bar": "^7.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.13.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.0"
  }
}
