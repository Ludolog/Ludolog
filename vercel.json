{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "regions": ["fra1"],
  "crons": [
    {
      "path": "/api/cron/refresh-player-counts",
      "schedule": "7 3 * * *"
    },
    {
      "path": "/api/cron/refresh-prices",
      "schedule": "17 3 * * *"
    },
    {
      "path": "/api/cron/refresh-top-games",
      "schedule": "37 3 * * *"
    }
  ]
}
